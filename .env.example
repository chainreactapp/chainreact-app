# Copy to .env.local and fill in. Never commit .env.local.

# Supabase (fresh V2 project — see master plan §12)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption key for OAuth tokens at rest (32 bytes base64). DO NOT reuse the V1 key.
TOKEN_ENCRYPTION_KEY=

# HMAC key for signed OAuth state tokens (32 bytes base64). Distinct from TOKEN_ENCRYPTION_KEY.
OAUTH_STATE_SIGNING_KEY=

# Stripe (Slice-2+; left blank for Slice 1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI (deferred per master plan §5 #26 — left blank for Slice 1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Slack (Slice 1 vertical slice)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
